<view class="page-shell ui-page pb-40rpx min-h-screen relative">
  <!-- 1. 顶部日期控制栏 (悬浮风格) -->
  <view class="sticky top-0 z-10 px-24rpx py-16rpx bg-hex-F7F9FC backdrop-blur-md">
    <view
      class="bg-white rounded-full shadow-sm p-8rpx flex items-center justify-between pl-16rpx pr-8rpx h-88rpx box-border">

      <!-- 左箭头 (前一天) -->
      <view class="w-72rpx h-72rpx flex items-center justify-center active:bg-hex-F3F4F6 rounded-full transition-colors"
        bindtap="moveDate" data-delta="{{ -1 }}">
        <van-icon name="arrow-left" color="#6B7280" size="18px" />
      </view>

      <!-- 中间日期显示 (点击弹日历) -->
      <view class="flex items-center gap-12rpx px-24rpx py-8rpx active:bg-hex-F9FAFB rounded-16rpx transition-colors"
        bindtap="showCalendar">
        <van-icon name="calendar-o" color="#0D9488" size="18px" />
        <view class="text-32rpx font-bold font-numeric text-hex-1F2937 pt-4rpx">{{ selectedDate }}</view>
      </view>

      <!-- 右箭头 (后一天) -->
      <view class="flex items-center gap-16rpx">
        <!-- 回到今天按钮 (仅当不是今天时显示) -->
        <view wx:if="{{ !isToday }}" bindtap="handleResetToday"
          class="text-22rpx text-hex-0D9488 bg-hex-F0FDFA px-16rpx py-8rpx rounded-full border border-hex-CCFBF1 font-medium transition-opacity">
          回今天
        </view>

        <view
          class="w-72rpx h-72rpx flex items-center justify-center active:bg-hex-F3F4F6 rounded-full transition-colors {{ isToday ? 'opacity-30' : '' }}"
          bindtap="moveDate" data-delta="{{ 1 }}">
          <van-icon name="arrow" color="#6B7280" size="18px" />
        </view>
      </view>

    </view>
  </view>

  <!-- 2. 内容区域 -->
  <view class="px-24rpx mt-16rpx">

    <!-- 加载中 -->
    <view wx:if="{{ loading }}" class="flex flex-col items-center justify-center py-100rpx">
      <van-loading color="#0D9488" size="32px" vertical>加载记录中...</van-loading>
    </view>

    <!-- 空状态 -->
    <view wx:elif="{{ !userList.length }}" class="flex flex-col items-center justify-center pt-120rpx opacity-60">
      <view class="w-160rpx h-160rpx bg-hex-E5E7EB rounded-full flex items-center justify-center mb-32rpx">
        <van-icon name="description" size="48px" color="#9CA3AF" />
      </view>
      <view class="text-30rpx text-hex-6B7280 font-medium">该日暂无操作记录</view>
      <view class="mt-24rpx">
        <van-button wx:if="{{ !isToday }}" round type="primary" size="small" color="#0D9488"
          bind:click="handleResetToday">查看今天</van-button>
      </view>
    </view>

    <!-- 用户列表 -->
    <view wx:else class="flex flex-col gap-24rpx pb-60rpx">
      <view wx:for="{{ userList }}" wx:key="index"
        class="bg-white rounded-32rpx p-32rpx shadow-sm active:scale-98 transition-transform" bindtap="goToDetail"
        data-user-id="{{ item.user.id }}">

        <!-- 用户信息行 -->
        <view class="flex items-center justify-between mb-24rpx">
          <view class="flex items-center gap-16rpx">
            <view class="w-88rpx h-88rpx bg-hex-EFF6FF rounded-full flex items-center justify-center flex-shrink-0">
              <van-icon name="manager" color="#3B82F6" size="24px" />
            </view>
            <view class="flex flex-col gap-4rpx">
              <view class="flex items-center gap-12rpx">
                <view class="text-30rpx font-bold text-hex-1F2937">{{ item.user.username }}</view>
                <view wx:if="{{ item.user.isAiAgent }}"
                  class="bg-gradient-to-br from-hex-3B82F6 to-hex-A855F7 text-white text-18rpx px-10rpx py-2rpx rounded-full shadow-sm">
                  AI
                </view>
              </view>
              <view wx:if="{{ item.user.stats }}" class="text-24rpx text-hex-6B7280">
                总资产 {{ item.user.stats.totalAssets }}
              </view>
            </view>
          </view>
          <van-icon name="arrow" color="#D1D5DB" size="16px" />
        </view>

        <!-- 统计数据行 -->
        <view class="flex items-center gap-32rpx">
          <view class="flex items-center gap-8rpx">
            <view class="text-32rpx font-bold text-hex-1F2937">{{ item.counts.total }}</view>
            <view class="text-22rpx text-hex-6B7280">笔</view>
          </view>
          <view class="flex items-center gap-8rpx">
            <view class="w-16rpx h-16rpx rounded-full bg-hex-EF4444"></view>
            <view class="text-24rpx text-hex-6B7280">买 {{ item.counts.buy }}</view>
          </view>
          <view class="flex items-center gap-8rpx">
            <view class="w-16rpx h-16rpx rounded-full bg-hex-22C55E"></view>
            <view class="text-24rpx text-hex-6B7280">卖 {{ item.counts.sell }}</view>
          </view>
          <view class="flex items-center gap-8rpx">
            <view class="w-16rpx h-16rpx rounded-full bg-hex-F59E0B"></view>
            <view class="text-24rpx text-hex-6B7280">待确认 {{ item.counts.pending }}</view>
          </view>
        </view>

        <!-- 处理中状态 -->
        <view wx:if="{{ item.loading }}" class="mt-20rpx flex items-center gap-8rpx">
          <van-loading color="#0D9488" size="16px" />
          <view class="text-22rpx text-hex-0D9488">AI 处理中...</view>
        </view>

      </view>
    </view>
  </view>

  <!-- 3. 日历弹窗 -->
  <van-calendar show="{{ showCalendar }}" color="#0D9488" show-confirm="{{ false }}" min-date="{{ minDate }}"
    max-date="{{ maxDate }}" bind:close="onCalendarClose" bind:confirm="onCalendarConfirm" />

  <van-toast id="van-toast" />
</view>